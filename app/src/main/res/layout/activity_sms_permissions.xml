<?xml version="1.0" encoding="utf-8"?>
<!-- SMS Notification Permission Screen -->
<!-- Explains why SMS permission is needed -->

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvSMSTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enable SMS Alerts"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp"/>

    <!-- Explanation -->
    <TextView
        android:id="@+id/tvSMSDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Receive automatic text alerts when inventory reaches zero. You can disable this feature at any time."
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSMSTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Enable SMS Button -->
    <Button
        android:id="@+id/btnEnableSMS"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enable SMS Notifications"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvSMSDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Continue Without SMS -->
    <Button
        android:id="@+id/btnSkipSMS"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Continue Without SMS"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnEnableSMS"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
